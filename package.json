{
  "name": "@motioncomplex/cosmos-lib",
  "publishConfig": {
    "access": "restricted"
  },
  "version": "1.0.0",
  "description": "Reusable astronomical utilities: data, math, media, sky maps, NASA APIs, and UI transitions.",
  "author": "",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./three": {
      "import": "./dist/three/index.js",
      "require": "./dist/three/index.cjs",
      "types": "./dist/three/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --declarationDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^1.2.0",
    "happy-dom": "^13.3.0",
    "three": "^0.160.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "keywords": [
    "astronomy",
    "celestial",
    "nasa",
    "skymap",
    "coordinates",
    "three.js",
    "space"
  ],
  "sideEffects": false
}
