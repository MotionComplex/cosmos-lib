{
  "name": "@motioncomplex/cosmos-lib",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "version": "1.0.16",
  "description": "Reusable astronomical utilities: data, math, media, sky maps, NASA APIs, and UI transitions.",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MotionComplex/cosmos-lib.git"
  },
  "type": "module",
  "files": [
    "dist",
    "!dist/**/*.map",
    "!dist/bundle-analysis.html",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./three": {
      "types": "./dist/three/index.d.ts",
      "import": "./dist/three/index.js",
      "require": "./dist/three/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --declarationDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "docs": "typedoc",
    "size": "npm run build && node -e \"const s=require('fs').statSync('dist/index.cjs').size;console.log('CJS:',Math.round(s/1024)+'KB');if(s>200000){console.error('Bundle exceeds 200KB!');process.exit(1)}\"",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "^20.8.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup-plugin-visualizer": "^6.0.11",
    "three": "^0.160.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.3.3",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "keywords": [
    "astronomy",
    "celestial",
    "nasa",
    "skymap",
    "coordinates",
    "three.js",
    "space"
  ],
  "sideEffects": false
}
